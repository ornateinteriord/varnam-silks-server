# ============================================
# ENVIRONMENT MODE
# ============================================
# Set this to 'development' for testing or 'production' for live
NODE_ENV=development

# ============================================
# PAYMENT MODE (IMPORTANT!)
# ============================================
# Set to 'SANDBOX' for testing or 'PRODUCTION' for live payments
PAYMENT_MODE=SANDBOX

# ============================================
# CASHFREE SANDBOX (TEST) CREDENTIALS
# ============================================
CASHFREE_SANDBOX_APP_ID=TEST1089421775b25afe7f2e6158714871249801
CASHFREE_SANDBOX_SECRET_KEY=cfsk_ma_test_your_sandbox_secret_key_here
CASHFREE_SANDBOX_WEBHOOK_SECRET=your_sandbox_webhook_secret

# ============================================
# CASHFREE PRODUCTION (LIVE) CREDENTIALS
# ============================================
CASHFREE_PRODUCTION_APP_ID=your_production_app_id_here
CASHFREE_PRODUCTION_SECRET_KEY=your_production_secret_key_here
CASHFREE_PRODUCTION_WEBHOOK_SECRET=your_production_webhook_secret

# ============================================
# FRONTEND URLs
# ============================================
FRONTEND_URL_DEV=http://localhost:5173
FRONTEND_URL_PROD=https://nidhi-ltd.vercel.app

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
PROJECT_NAME=MSCS Server

# ============================================
# DATABASE
# ============================================
MONGO_URI=your_mongodb_connection_string

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ============================================
# IMAGEKIT (Optional)
# ============================================
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id

# ============================================
# USAGE INSTRUCTIONS
# ============================================
# 1. To TEST payments: Set PAYMENT_MODE=SANDBOX
# 2. To use LIVE payments: Set PAYMENT_MODE=PRODUCTION
# 3. The app will automatically use the correct credentials
